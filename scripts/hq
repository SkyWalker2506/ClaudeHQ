#!/usr/bin/env bash
set -euo pipefail

# ClaudeHQ — Central Project Management CLI
# Usage: hq <command> [options]

HQ_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECTS_ROOT="${HQ_PROJECTS_ROOT:-$HOME/Projects}"
PROGRESS_DIR="$HQ_DIR/progress"
SPRINTS_DIR="$HQ_DIR/sprints"
PROJECTS_FILE="$HQ_DIR/projects.json"
TEMPLATES_DIR="$HQ_DIR/templates"
FEATURES_DIR="$HQ_DIR/features"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
GRAY='\033[0;90m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    cat <<EOF
${BOLD}ClaudeHQ — Project Management CLI${NC}

${BOLD}Usage:${NC} hq <command> [options]

${BOLD}Commands:${NC}
  scan                              Scan ~/Projects for CLAUDE.md projects
  new <name> [--jira KEY]           Create a new project with full ecosystem setup
  session <project|--all>           Launch Claude session(s) for project(s)
  dispatch <project|--all>          Deprecated alias for session
  status [project]                  Show project status dashboard
  sprint plan <project>             Launch sprint planning session
  sprint list [project]             List sprints
  sprint init <project>             Initialize sprint tracking for a project
  feature start <name> [--repos=..]  Start a cross-repo feature branch
  feature status <name>             Show feature branch status across repos
  feature commit <name> -m "msg"    Commit changes in all repos with changes
  monitor [--watch]                 Watch running sessions
  stuck                             Show stuck/blocked projects
  archive <project>                 Mark project as inactive
  activate <project>                Mark project as active
  config [project]                  Show/edit project configuration
  logs <project>                    Show session logs for a project
  sync [--dry-run]                  Sync ecosystem stats to all downstream README pages
  bootstrap [--all]                 Full ecosystem setup on a new machine
  doctor                            Health check: symlinks, paths, git remotes, dep cycles

${BOLD}Options:${NC}
  --dry-run                   Show what would happen without executing
  --help, -h                  Show this help message

${BOLD}Environment:${NC}
  HQ_PROJECTS_ROOT            Override projects root (default: ~/Projects)

${BOLD}Examples:${NC}
  hq scan                     Discover all projects
  hq new my-app --jira MA     Create new project
  hq session VocabLearningApp
  hq session --all            Launch all active projects
  hq status                   Show dashboard
  hq monitor --watch          Live monitoring
  hq logs trading-bot         Show logs
  hq archive old-project      Deactivate project
EOF
}

# --- SCAN ---
cmd_scan() {
    if [[ ! -d "$PROJECTS_ROOT" ]]; then
        echo -e "${RED}Error:${NC} Projects root not found: $PROJECTS_ROOT"
        echo "Set HQ_PROJECTS_ROOT or create $PROJECTS_ROOT"
        exit 1
    fi

    echo -e "${BLUE}Scanning${NC} $PROJECTS_ROOT for CLAUDE.md projects..."

    mkdir -p "$HQ_DIR/workspaces"

    local projects="[]"
    local count=0

    while IFS= read -r claude_md; do
        local project_dir
        project_dir="$(dirname "$claude_md")"
        local project_name
        project_name="$(basename "$project_dir")"

        # Skip ClaudeHQ itself
        if [[ "$project_name" == "ClaudeHQ" ]]; then
            continue
        fi

        # Extract git remote
        local git_remote=""
        if [[ -f "$project_dir/.git/config" ]]; then
            git_remote=$(grep -A1 '\[remote "origin"\]' "$project_dir/.git/config" 2>/dev/null | grep url | sed 's/.*github.com[:/]\(.*\)\.git/\1/' | sed 's/.*github.com[:/]\(.*\)/\1/' | tr -d '[:space:]' || true)
        fi

        # Extract jira key from .claude/index.md
        local jira_key=""
        if [[ -f "$project_dir/.claude/index.md" ]]; then
            jira_key=$(grep -i '^jira:' "$project_dir/.claude/index.md" 2>/dev/null | head -1 | sed 's/^jira:[[:space:]]*//' | tr -d '[:space:]' || true)
        fi

        # Check if already in projects.json to preserve active/sprint state
        local existing_active="true"
        local existing_sprint="null"
        if [[ -f "$PROJECTS_FILE" ]]; then
            existing_active=$(jq -r --arg name "$project_name" '.[] | select(.name == $name) | .active // true' "$PROJECTS_FILE" 2>/dev/null || echo "true")
            existing_sprint=$(jq -r --arg name "$project_name" '.[] | select(.name == $name) | .currentSprint // null' "$PROJECTS_FILE" 2>/dev/null || echo "null")
            [[ -z "$existing_active" ]] && existing_active="true"
            [[ -z "$existing_sprint" ]] && existing_sprint="null"
        fi

        # Build project entry
        local entry
        entry=$(jq -n \
            --arg name "$project_name" \
            --arg path "$project_dir" \
            --arg jira "$jira_key" \
            --arg git "$git_remote" \
            --argjson active "$existing_active" \
            --argjson sprint "$existing_sprint" \
            --arg date "$(date +%Y-%m-%d)" \
            '{
                name: $name,
                path: $path,
                jira: (if $jira == "" then null else $jira end),
                git: (if $git == "" then null else $git end),
                active: $active,
                currentSprint: $sprint,
                discoveredAt: $date
            }')

        projects=$(echo "$projects" | jq --argjson entry "$entry" '. + [$entry]')
        count=$((count + 1))

        # Create workspace symlink for new project
        local proj_path="$project_dir"
        ln -sfn "$proj_path" "$HQ_DIR/workspaces/$(basename "$proj_path")"

        echo -e "  ${GREEN}+${NC} $project_name $([ -n "$jira_key" ] && echo "[${jira_key}]" || true) $([ -n "$git_remote" ] && echo "($git_remote)" || true)"

    done < <(find "$PROJECTS_ROOT" -maxdepth 2 -name "CLAUDE.md" -not -path "*/node_modules/*" 2>/dev/null | sort)

    # Write projects.json
    echo "$projects" | jq '.' > "$PROJECTS_FILE"

    echo ""
    echo -e "${GREEN}Found $count project(s).${NC} Written to projects.json"
}

# --- SESSION ---
cmd_session() {
    local target="${1:-}"
    local dry_run=false

    # Parse flags
    for arg in "$@"; do
        case "$arg" in
            --dry-run) dry_run=true ;;
        esac
    done

    if [[ -z "$target" ]]; then
        echo -e "${RED}Usage:${NC} hq session <project|--all> [--dry-run]"
        exit 1
    fi

    if [[ ! -f "$PROJECTS_FILE" ]]; then
        echo -e "${RED}Error:${NC} projects.json not found. Run 'hq scan' first."
        exit 1
    fi

    mkdir -p "$PROGRESS_DIR"

    if [[ "$target" == "--all" ]]; then
        local project_names
        project_names=$(jq -r '.[] | select(.active == true) | .name' "$PROJECTS_FILE")

        if [[ -z "$project_names" ]]; then
            echo -e "${YELLOW}No active projects found.${NC}"
            exit 0
        fi

        echo -e "${BLUE}Launching all active project sessions...${NC}"
        while IFS= read -r name; do
            dispatch_project "$name" "$dry_run"
        done <<< "$project_names"
    else
        dispatch_project "$target" "$dry_run"
    fi
}

# --- DISPATCH (deprecated alias for session) ---
cmd_dispatch() {
    echo "⚠️  'hq dispatch' is deprecated. Use 'hq session' instead." >&2
    cmd_session "$@"
}

dispatch_project() {
    local project_name="$1"
    local dry_run="${2:-false}"

    # Get project info
    local project_path
    project_path=$(jq -r --arg name "$project_name" '.[] | select(.name == $name) | .path' "$PROJECTS_FILE")

    if [[ -z "$project_path" || "$project_path" == "null" ]]; then
        echo -e "${RED}Error:${NC} Project '$project_name' not found in projects.json"
        return 1
    fi

    # Build prompt
    local prompt
    prompt=$("$HQ_DIR/scripts/dispatch.sh" build-prompt "$project_name")

    if [[ "$dry_run" == "true" ]]; then
        echo -e "${YELLOW}[DRY RUN]${NC} $project_name"
        echo -e "${GRAY}Path:${NC} $project_path"
        echo -e "${GRAY}Prompt:${NC}"
        echo "$prompt"
        echo "---"
        return 0
    fi

    echo -e "${BLUE}Dispatching${NC} $project_name..."

    # Write initial progress
    local progress_file="$PROGRESS_DIR/${project_name}.json"
    jq -n \
        --arg name "$project_name" \
        --arg status "dispatching" \
        --arg time "$(date -Iseconds)" \
        '{project: $name, status: $status, startedAt: $time, pid: null, lastUpdate: $time}' \
        > "$progress_file"

    # Launch Claude in background
    "$HQ_DIR/scripts/dispatch.sh" run "$project_name" &
    local pid=$!

    # Update progress with PID
    jq --argjson pid "$pid" '.pid = $pid | .status = "running"' "$progress_file" > "${progress_file}.tmp" && mv "${progress_file}.tmp" "$progress_file"

    echo -e "  ${GREEN}Started${NC} $project_name (PID: $pid)"
}

# --- STATUS ---
cmd_status() {
    local filter="${1:-}"

    if [[ ! -f "$PROJECTS_FILE" ]]; then
        echo -e "${YELLOW}No projects found.${NC} Run 'hq scan' first."
        exit 0
    fi

    local projects
    projects=$(jq -r '.[] | .name' "$PROJECTS_FILE")

    if [[ -z "$projects" ]]; then
        echo -e "${YELLOW}No projects in projects.json.${NC}"
        exit 0
    fi

    # Header
    printf "\n${BOLD}%-25s %-10s %-10s %-12s %-15s${NC}\n" "PROJECT" "SPRINT" "TASKS" "STATUS" "LAST UPDATE"
    printf "%-25s %-10s %-10s %-12s %-15s\n" "-------" "------" "-----" "------" "-----------"

    while IFS= read -r name; do
        # Skip if filter specified and doesn't match
        if [[ -n "$filter" && "$name" != "$filter" ]]; then
            continue
        fi

        local sprint="-"
        local tasks="-"
        local status="idle"
        local last_update="-"
        local status_color="$GRAY"

        # Check sprint info
        local active_sprint
        active_sprint=$(jq -r --arg name "$name" '.[] | select(.name == $name) | .currentSprint // empty' "$PROJECTS_FILE" 2>/dev/null || true)
        if [[ -n "$active_sprint" && "$active_sprint" != "null" ]]; then
            sprint="S$active_sprint"

            # Count tasks
            local sprint_file="$SPRINTS_DIR/$name/sprint-${active_sprint}.json"
            if [[ -f "$sprint_file" ]]; then
                local total done_count
                total=$(jq '.tasks | length' "$sprint_file" 2>/dev/null || echo 0)
                done_count=$(jq '[.tasks[] | select(.status == "done")] | length' "$sprint_file" 2>/dev/null || echo 0)
                tasks="${done_count}/${total}"
            fi
        fi

        # Check progress
        local progress_file="$PROGRESS_DIR/${name}.json"
        if [[ -f "$progress_file" ]]; then
            status=$(jq -r '.status // "unknown"' "$progress_file" 2>/dev/null || echo "unknown")

            local update_time
            update_time=$(jq -r '.lastUpdate // empty' "$progress_file" 2>/dev/null || true)
            if [[ -n "$update_time" ]]; then
                local now update_epoch diff
                now=$(date +%s)
                update_epoch=$(date -d "$update_time" +%s 2>/dev/null || echo "$now")
                diff=$(( now - update_epoch ))

                if (( diff < 60 )); then
                    last_update="${diff}s ago"
                elif (( diff < 3600 )); then
                    last_update="$(( diff / 60 ))m ago"
                elif (( diff < 86400 )); then
                    last_update="$(( diff / 3600 ))h ago"
                else
                    last_update="$(( diff / 86400 ))d ago"
                fi
            fi
        fi

        # Color based on status
        case "$status" in
            running|dispatching) status_color="$YELLOW" ;;
            done|completed)      status_color="$GREEN" ;;
            stuck|failed|error)  status_color="$RED" ;;
            idle|unknown)        status_color="$GRAY" ;;
        esac

        printf "%-25s %-10s %-10s ${status_color}%-12s${NC} %-15s\n" "$name" "$sprint" "$tasks" "$status" "$last_update"

    done <<< "$projects"
    echo ""
}

# --- SPRINT ---
cmd_sprint() {
    local subcmd="${1:-}"
    local project="${2:-}"

    case "$subcmd" in
        plan)
            if [[ -z "$project" ]]; then
                echo -e "${RED}Usage:${NC} hq sprint plan <project>"
                exit 1
            fi
            sprint_plan "$project"
            ;;
        list)
            sprint_list "$project"
            ;;
        init)
            if [[ -z "$project" ]]; then
                echo -e "${RED}Usage:${NC} hq sprint init <project>"
                exit 1
            fi
            sprint_init "$project"
            ;;
        *)
            echo -e "${RED}Usage:${NC} hq sprint <plan|list|init> [project]"
            exit 1
            ;;
    esac
}

sprint_init() {
    local project="$1"
    local sprint_dir="$SPRINTS_DIR/$project"
    mkdir -p "$sprint_dir"

    if [[ -f "$sprint_dir/sprint-1.json" ]]; then
        echo -e "${YELLOW}Sprint 1 already exists for $project.${NC}"
        return 0
    fi

    # Copy template
    local template="$TEMPLATES_DIR/sprint.json"
    if [[ ! -f "$template" ]]; then
        echo -e "${RED}Error:${NC} Sprint template not found at $template"
        exit 1
    fi

    jq --arg project "$project" --arg date "$(date +%Y-%m-%d)" \
        '.project = $project | .startDate = $date' \
        "$template" > "$sprint_dir/sprint-1.json"

    # Update currentSprint in projects.json
    if [[ -f "$PROJECTS_FILE" ]]; then
        jq --arg name "$project" '(.[] | select(.name == $name) | .currentSprint) = 1' "$PROJECTS_FILE" > "${PROJECTS_FILE}.tmp" && mv "${PROJECTS_FILE}.tmp" "$PROJECTS_FILE"
    fi

    echo -e "${GREEN}Initialized${NC} sprint 1 for $project"
    echo "Edit: $sprint_dir/sprint-1.json"
}

sprint_plan() {
    local project="$1"

    if [[ ! -f "$PROJECTS_FILE" ]]; then
        echo -e "${RED}Error:${NC} projects.json not found. Run 'hq scan' first."
        exit 1
    fi

    local project_path
    project_path=$(jq -r --arg name "$project" '.[] | select(.name == $name) | .path' "$PROJECTS_FILE")

    if [[ -z "$project_path" || "$project_path" == "null" ]]; then
        echo -e "${RED}Error:${NC} Project '$project' not found."
        exit 1
    fi

    local prompt_template="$TEMPLATES_DIR/task-prompts/plan-sprint.md"
    if [[ ! -f "$prompt_template" ]]; then
        echo -e "${RED}Error:${NC} plan-sprint.md template not found."
        exit 1
    fi

    local sprint_dir="$SPRINTS_DIR/$project"
    mkdir -p "$sprint_dir"

    # Determine next sprint number
    local next_sprint=1
    local latest
    latest=$(ls "$sprint_dir"/sprint-*.json 2>/dev/null | sort -V | tail -1 || true)
    if [[ -n "$latest" ]]; then
        next_sprint=$(( $(basename "$latest" | grep -oP '\d+') + 1 ))
    fi

    local prompt
    prompt=$(sed \
        -e "s|{{PROJECT_NAME}}|$project|g" \
        -e "s|{{PROJECT_PATH}}|$project_path|g" \
        -e "s|{{SPRINT_NUMBER}}|$next_sprint|g" \
        -e "s|{{SPRINT_DIR}}|$sprint_dir|g" \
        "$prompt_template")

    echo -e "${BLUE}Launching sprint planning for $project (Sprint $next_sprint)...${NC}"

    cd "$project_path"
    claude -p \
        --model sonnet \
        --name "hq-sprint-$project" \
        --append-system-prompt "$prompt" \
        "Plan sprint $next_sprint for this project. Analyze the codebase, identify priorities, and create the sprint file."
}

sprint_list() {
    local filter="${1:-}"

    if [[ ! -d "$SPRINTS_DIR" ]]; then
        echo -e "${YELLOW}No sprints directory found.${NC}"
        exit 0
    fi

    echo -e "\n${BOLD}Sprints:${NC}\n"

    for project_dir in "$SPRINTS_DIR"/*/; do
        [[ ! -d "$project_dir" ]] && continue
        local project_name
        project_name=$(basename "$project_dir")

        if [[ -n "$filter" && "$project_name" != "$filter" ]]; then
            continue
        fi

        echo -e "${BOLD}$project_name${NC}"

        for sprint_file in "$project_dir"/sprint-*.json; do
            [[ ! -f "$sprint_file" ]] && continue
            local num status goal total done_count
            num=$(jq -r '.sprint' "$sprint_file")
            status=$(jq -r '.status' "$sprint_file")
            goal=$(jq -r '.goal // "-"' "$sprint_file")
            total=$(jq '.tasks | length' "$sprint_file")
            done_count=$(jq '[.tasks[] | select(.status == "done")] | length' "$sprint_file")

            local status_color="$GRAY"
            case "$status" in
                active)    status_color="$YELLOW" ;;
                completed) status_color="$GREEN" ;;
                planning)  status_color="$BLUE" ;;
            esac

            printf "  Sprint %-3s ${status_color}%-12s${NC} [%s/%s] %s\n" "$num" "$status" "$done_count" "$total" "$goal"
        done
        echo ""
    done
}

# --- MONITOR ---
cmd_monitor() {
    local watch=false

    for arg in "$@"; do
        case "$arg" in
            --watch) watch=true ;;
        esac
    done

    if [[ "$watch" == "true" ]]; then
        while true; do
            clear
            echo -e "${BOLD}ClaudeHQ Monitor${NC} — $(date '+%H:%M:%S')"
            echo ""
            show_monitor_table
            echo -e "${GRAY}Refreshing every 30s... (Ctrl+C to stop)${NC}"
            sleep 30
        done
    else
        show_monitor_table
    fi
}

show_monitor_table() {
    if [[ ! -d "$PROGRESS_DIR" ]] || ! ls "$PROGRESS_DIR"/*.json >/dev/null 2>&1; then
        echo -e "${YELLOW}No active sessions.${NC}"
        return 0
    fi

    printf "${BOLD}%-25s %-8s %-12s %-15s %-10s${NC}\n" "PROJECT" "PID" "STATUS" "LAST UPDATE" "DURATION"
    printf "%-25s %-8s %-12s %-15s %-10s\n" "-------" "---" "------" "-----------" "--------"

    for progress_file in "$PROGRESS_DIR"/*.json; do
        [[ ! -f "$progress_file" ]] && continue

        local name pid status started last_update
        name=$(jq -r '.project' "$progress_file")
        pid=$(jq -r '.pid // "-"' "$progress_file")
        status=$(jq -r '.status // "unknown"' "$progress_file")
        started=$(jq -r '.startedAt // empty' "$progress_file" 2>/dev/null || true)
        last_update=$(jq -r '.lastUpdate // empty' "$progress_file" 2>/dev/null || true)

        # Check if PID is still alive
        if [[ "$pid" != "-" && "$pid" != "null" ]]; then
            if ! kill -0 "$pid" 2>/dev/null; then
                if [[ "$status" == "running" || "$status" == "dispatching" ]]; then
                    status="finished"
                    jq '.status = "finished"' "$progress_file" > "${progress_file}.tmp" && mv "${progress_file}.tmp" "$progress_file"
                fi
            fi
        fi

        # Check for stuck (>10 min without update)
        if [[ -n "$last_update" && "$status" == "running" ]]; then
            local now update_epoch diff
            now=$(date +%s)
            update_epoch=$(date -d "$last_update" +%s 2>/dev/null || echo "$now")
            diff=$(( now - update_epoch ))
            if (( diff > 600 )); then
                status="stuck"
                jq '.status = "stuck"' "$progress_file" > "${progress_file}.tmp" && mv "${progress_file}.tmp" "$progress_file"
            fi
        fi

        # Duration
        local duration="-"
        if [[ -n "$started" ]]; then
            local now start_epoch
            now=$(date +%s)
            start_epoch=$(date -d "$started" +%s 2>/dev/null || echo "$now")
            local dur=$(( now - start_epoch ))
            if (( dur < 60 )); then
                duration="${dur}s"
            elif (( dur < 3600 )); then
                duration="$(( dur / 60 ))m"
            else
                duration="$(( dur / 3600 ))h$(( (dur % 3600) / 60 ))m"
            fi
        fi

        # Format last update
        local update_str="-"
        if [[ -n "$last_update" ]]; then
            local now update_epoch diff
            now=$(date +%s)
            update_epoch=$(date -d "$last_update" +%s 2>/dev/null || echo "$now")
            diff=$(( now - update_epoch ))
            if (( diff < 60 )); then
                update_str="${diff}s ago"
            elif (( diff < 3600 )); then
                update_str="$(( diff / 60 ))m ago"
            else
                update_str="$(( diff / 3600 ))h ago"
            fi
        fi

        local status_color="$GRAY"
        case "$status" in
            running|dispatching) status_color="$YELLOW" ;;
            done|completed|finished) status_color="$GREEN" ;;
            stuck|failed|error) status_color="$RED" ;;
        esac

        printf "%-25s %-8s ${status_color}%-12s${NC} %-15s %-10s\n" "$name" "$pid" "$status" "$update_str" "$duration"
    done
    echo ""
}

# --- STUCK ---
cmd_stuck() {
    if [[ ! -d "$PROGRESS_DIR" ]] || ! ls "$PROGRESS_DIR"/*.json >/dev/null 2>&1; then
        echo -e "${GREEN}No stuck projects.${NC}"
        return 0
    fi

    local found=false

    echo -e "\n${BOLD}Stuck / Blocked Projects:${NC}\n"

    for progress_file in "$PROGRESS_DIR"/*.json; do
        [[ ! -f "$progress_file" ]] && continue

        local name status pid last_update
        name=$(jq -r '.project' "$progress_file")
        status=$(jq -r '.status // "unknown"' "$progress_file")
        pid=$(jq -r '.pid // "-"' "$progress_file")
        last_update=$(jq -r '.lastUpdate // empty' "$progress_file" 2>/dev/null || true)

        local is_stuck=false

        # Check explicit stuck/failed status
        if [[ "$status" == "stuck" || "$status" == "failed" || "$status" == "error" ]]; then
            is_stuck=true
        fi

        # Check PID dead but status still running
        if [[ "$pid" != "-" && "$pid" != "null" && "$status" == "running" ]]; then
            if ! kill -0 "$pid" 2>/dev/null; then
                is_stuck=true
                status="dead-process"
            fi
        fi

        # Check timeout (>10 min without update)
        if [[ -n "$last_update" && "$status" == "running" ]]; then
            local now update_epoch diff
            now=$(date +%s)
            update_epoch=$(date -d "$last_update" +%s 2>/dev/null || echo "$now")
            diff=$(( now - update_epoch ))
            if (( diff > 600 )); then
                is_stuck=true
                status="timeout"
            fi
        fi

        if [[ "$is_stuck" == "true" ]]; then
            found=true
            echo -e "  ${RED}*${NC} ${BOLD}$name${NC} — status: $status (PID: $pid)"

            # Show log tail if exists
            local log_file="$PROGRESS_DIR/${name}.log"
            if [[ -f "$log_file" ]]; then
                echo -e "    ${GRAY}Last output:${NC}"
                tail -3 "$log_file" 2>/dev/null | sed 's/^/    /'
            fi
            echo ""
        fi
    done

    if [[ "$found" == "false" ]]; then
        echo -e "  ${GREEN}No stuck projects!${NC}"
    fi
    echo ""
}

# --- NEW PROJECT ---
cmd_new() {
    local project_name=""
    local jira_key=""
    local git_org="SkyWalker2506"
    local template=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --jira)  jira_key="${2:-}"; shift 2 ;;
            --git-org) git_org="${2:-}"; shift 2 ;;
            --template) template="${2:-}"; shift 2 ;;
            -*) echo -e "${RED}Unknown option:${NC} $1"; exit 1 ;;
            *)  project_name="$1"; shift ;;
        esac
    done

    if [[ -z "$project_name" ]]; then
        echo -e "${RED}Usage:${NC} hq new <project-name> [--jira KEY] [--git-org ORG] [--template NAME]"
        exit 1
    fi

    local project_path="$PROJECTS_ROOT/$project_name"

    if [[ -d "$project_path" ]]; then
        echo -e "${RED}Error:${NC} Directory already exists: $project_path"
        exit 1
    fi

    echo -e "${BLUE}Creating project${NC} $project_name..."

    # 1. Create directory and init git
    mkdir -p "$project_path"
    cd "$project_path"
    git init -q

    echo -e "  ${GREEN}+${NC} Created $project_path"
    echo -e "  ${GREEN}+${NC} Initialized git repository"

    # 2. Create CLAUDE.md
    cat > "$project_path/CLAUDE.md" <<CLAUDEMD
# $project_name

## Bu proje nedir

$project_name projesi.

## Kurallar

- Commit mesajlari aciklayici olsun
- Test yazmayi unutma
- PR acmadan once lint kontrol et
CLAUDEMD
    echo -e "  ${GREEN}+${NC} Created CLAUDE.md"

    # 3. Create .claude/index.md
    mkdir -p "$project_path/.claude"
    cat > "$project_path/.claude/index.md" <<INDEXMD
---
project: $project_name
stack:
jira: ${jira_key:-}
git: ${git_org}/${project_name}
---
$project_name projesi.
INDEXMD
    echo -e "  ${GREEN}+${NC} Created .claude/index.md"

    # 4. Create .gitignore
    cat > "$project_path/.gitignore" <<GITIGNORE
.env
.env.*
*.env
.DS_Store
node_modules/
.claude/
GITIGNORE
    echo -e "  ${GREEN}+${NC} Created .gitignore"

    # 5. Create README.md
    cat > "$project_path/README.md" <<README
# $project_name

> Created via ClaudeHQ

## Setup

\`\`\`bash
cd $project_path
claude
\`\`\`
README
    echo -e "  ${GREEN}+${NC} Created README.md"

    # 6. Run claude-config install if available
    local config_installer="$PROJECTS_ROOT/claude-config/install.sh"
    if [[ -x "$config_installer" ]]; then
        echo -e "  ${BLUE}Running${NC} claude-config install..."
        cd "$PROJECTS_ROOT/claude-config" && ./install.sh 2>/dev/null || true
        echo -e "  ${GREEN}+${NC} claude-config installed"
    fi

    # 7. Initial commit
    cd "$project_path"
    git add -A
    git commit -q -m "Initial project setup via ClaudeHQ"
    echo -e "  ${GREEN}+${NC} Initial commit created"

    # 8. Create GitHub repo if gh is available
    if command -v gh &>/dev/null; then
        echo -e "  ${BLUE}Creating${NC} GitHub repo ${git_org}/${project_name}..."
        if gh repo create "${git_org}/${project_name}" --private --source=. --push 2>/dev/null; then
            echo -e "  ${GREEN}+${NC} GitHub repo created and pushed"
        else
            echo -e "  ${YELLOW}!${NC} GitHub repo creation failed (may already exist or no auth)"
        fi
    fi

    # 9. Initialize sprint tracking
    mkdir -p "$SPRINTS_DIR/$project_name"
    jq --arg project "$project_name" --arg date "$(date +%Y-%m-%d)" \
        '.project = $project | .startDate = $date' \
        "$TEMPLATES_DIR/sprint.json" > "$SPRINTS_DIR/$project_name/sprint-1.json"
    echo -e "  ${GREEN}+${NC} Sprint 1 initialized"

    # 10. Re-scan to add to projects.json
    echo ""
    cmd_scan

    echo ""
    echo -e "${GREEN}Project $project_name created successfully!${NC}"
    echo ""
    echo -e "${BOLD}Next steps:${NC}"
    echo "  1. Edit sprints/$project_name/sprint-1.json to define tasks"
    echo "  2. hq session $project_name"
    echo "  3. hq status"
}

# --- ARCHIVE / ACTIVATE ---
cmd_archive() {
    local project="${1:?Usage: hq archive <project>}"
    toggle_active "$project" false "archived"
}

cmd_activate() {
    local project="${1:?Usage: hq activate <project>}"
    toggle_active "$project" true "activated"
}

toggle_active() {
    local project="$1"
    local active_val="$2"
    local action_label="$3"

    if [[ ! -f "$PROJECTS_FILE" ]]; then
        echo -e "${RED}Error:${NC} projects.json not found. Run 'hq scan' first."
        exit 1
    fi

    local exists
    exists=$(jq -r --arg name "$project" '.[] | select(.name == $name) | .name' "$PROJECTS_FILE" 2>/dev/null || true)

    if [[ -z "$exists" ]]; then
        echo -e "${RED}Error:${NC} Project '$project' not found in projects.json"
        exit 1
    fi

    jq --arg name "$project" --argjson active "$active_val" \
        '(.[] | select(.name == $name) | .active) = $active' \
        "$PROJECTS_FILE" > "${PROJECTS_FILE}.tmp" && mv "${PROJECTS_FILE}.tmp" "$PROJECTS_FILE"

    echo -e "${GREEN}Project '$project' ${action_label}.${NC}"
}

# --- CONFIG ---
cmd_config() {
    local project="${1:-}"

    if [[ ! -f "$PROJECTS_FILE" ]]; then
        echo -e "${RED}Error:${NC} projects.json not found. Run 'hq scan' first."
        exit 1
    fi

    if [[ -z "$project" ]]; then
        # Show all config
        echo -e "\n${BOLD}ClaudeHQ Configuration${NC}\n"
        echo -e "${GRAY}Projects root:${NC}  $PROJECTS_ROOT"
        echo -e "${GRAY}HQ directory:${NC}   $HQ_DIR"
        echo -e "${GRAY}Projects file:${NC}  $PROJECTS_FILE"
        echo ""
        echo -e "${BOLD}Projects:${NC}"
        jq -r '.[] | "  \(.name)\t\(if .active then "active" else "archived" end)\t\(.jira // "-")\t\(.git // "-")"' "$PROJECTS_FILE" | column -t -s $'\t'
    else
        # Show specific project config
        local info
        info=$(jq --arg name "$project" '.[] | select(.name == $name)' "$PROJECTS_FILE")

        if [[ -z "$info" ]]; then
            echo -e "${RED}Error:${NC} Project '$project' not found."
            exit 1
        fi

        echo -e "\n${BOLD}$project${NC}\n"
        echo "$info" | jq '.'

        # Show sprint info if exists
        local sprint_dir="$SPRINTS_DIR/$project"
        if [[ -d "$sprint_dir" ]]; then
            local sprint_count
            sprint_count=$(ls "$sprint_dir"/sprint-*.json 2>/dev/null | wc -l)
            echo -e "\n${GRAY}Sprints:${NC} $sprint_count"
        fi

        # Show progress if exists
        local progress_file="$PROGRESS_DIR/$project.json"
        if [[ -f "$progress_file" ]]; then
            echo -e "\n${GRAY}Last progress:${NC}"
            jq '.' "$progress_file"
        fi
    fi
    echo ""
}

# --- BOOTSTRAP ---
cmd_bootstrap() {
    local clone_all=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) clone_all=1; shift ;;
            --help|-h)
                cat <<BEOF
${BOLD}hq bootstrap${NC} — Full ecosystem setup on a new machine

${BOLD}Usage:${NC} hq bootstrap [--all]

${BOLD}Steps:${NC}
  1. Ensure gh auth is active
  2. Clone & install claude-config (agents, skills, hooks, MCP)
  3. Clone claude-secrets (private)
  4. Run install.sh (symlinks, shell config, secrets)
  5. Clone all project repos from projects.json (with --all)
  6. Run hq scan to regenerate projects.json

${BOLD}Options:${NC}
  --all    Clone ALL project repos (not just core infra)
BEOF
                return 0 ;;
            *) echo -e "${RED}Unknown option: $1${NC}"; return 1 ;;
        esac
    done

    echo -e "${BOLD}🚀 ClaudeHQ Bootstrap — Full Ecosystem Setup${NC}\n"

    # Step 0: Check prerequisites
    echo -e "${BLUE}[0/6]${NC} Checking prerequisites..."
    for cmd in git gh jq; do
        if ! command -v "$cmd" &>/dev/null; then
            echo -e "${RED}Missing:${NC} $cmd — install it first."
            exit 1
        fi
    done

    if ! gh auth status &>/dev/null; then
        echo -e "${YELLOW}GitHub CLI not authenticated. Running gh auth login...${NC}"
        gh auth login
    fi
    echo -e "${GREEN}✓${NC} Prerequisites OK\n"

    # Step 1: Clone claude-config
    echo -e "${BLUE}[1/6]${NC} claude-config..."
    local config_dir="$PROJECTS_ROOT/claude-config"
    if [[ -d "$config_dir/.git" ]]; then
        echo -e "  ${GREEN}✓${NC} Already exists — pulling latest"
        git -C "$config_dir" pull --quiet 2>/dev/null || true
    else
        echo -e "  Cloning..."
        gh repo clone SkyWalker2506/claude-config "$config_dir" -- --quiet
        echo -e "  ${GREEN}✓${NC} Cloned"
    fi

    # Step 2: Clone claude-secrets (private)
    echo -e "${BLUE}[2/6]${NC} claude-secrets..."
    local secrets_dir="$config_dir/claude-secrets"
    if [[ -d "$secrets_dir/.git" ]]; then
        echo -e "  ${GREEN}✓${NC} Already exists — pulling latest"
        git -C "$secrets_dir" pull --quiet 2>/dev/null || true
    else
        echo -e "  Cloning (private)..."
        if gh repo clone SkyWalker2506/claude-secrets "$secrets_dir" -- --quiet 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} Cloned"
        else
            echo -e "  ${YELLOW}⚠${NC}  Clone failed — run manually: gh repo clone SkyWalker2506/claude-secrets $secrets_dir"
        fi
    fi

    # Step 3: Run install.sh
    echo -e "${BLUE}[3/6]${NC} Running install.sh..."
    if [[ -f "$config_dir/install.sh" ]]; then
        bash "$config_dir/install.sh" --auto
        echo -e "  ${GREEN}✓${NC} install.sh completed"
    else
        echo -e "  ${RED}✗${NC} install.sh not found!"
        exit 1
    fi

    # Step 4: Clone core Claude ecosystem repos
    echo -e "${BLUE}[4/6]${NC} Core ecosystem repos..."
    local core_repos=(
        "SkyWalker2506/claude-marketplace:claude-marketplace"
        "SkyWalker2506/claude-agent-catalog:claude-agent-catalog"
    )
    for entry in "${core_repos[@]}"; do
        local repo="${entry%%:*}"
        local dir_name="${entry##*:}"
        local target="$PROJECTS_ROOT/$dir_name"
        if [[ -d "$target/.git" ]]; then
            echo -e "  ${GREEN}✓${NC} $dir_name (exists)"
            git -C "$target" pull --quiet 2>/dev/null || true
        else
            if gh repo clone "$repo" "$target" -- --quiet 2>/dev/null; then
                echo -e "  ${GREEN}✓${NC} $dir_name"
            else
                echo -e "  ${YELLOW}⚠${NC}  $dir_name — clone failed"
            fi
        fi
    done

    # Step 5: Clone all project repos (if --all)
    if [[ "$clone_all" -eq 1 ]]; then
        echo -e "${BLUE}[5/6]${NC} Cloning all project repos..."

        # Use committed bootstrap list or fall back to projects.json
        local repo_source="$HQ_DIR/projects.json"
        if [[ ! -f "$repo_source" ]]; then
            echo -e "  ${YELLOW}⚠${NC}  projects.json not found — skipping project repos"
            echo "  Run 'hq scan' after manually cloning projects"
        else
            local total
            total=$(jq '.projects | length' "$repo_source")
            local cloned=0
            for i in $(seq 0 $((total - 1))); do
                local name git_remote
                name=$(jq -r ".projects[$i].name" "$repo_source")
                git_remote=$(jq -r ".projects[$i].git // empty" "$repo_source")

                [[ -z "$git_remote" ]] && continue
                # Skip already handled repos
                [[ "$name" == "claude-config" || "$name" == "ClaudeHQ" ]] && continue

                local target="$PROJECTS_ROOT/$name"
                if [[ -d "$target/.git" ]]; then
                    echo -e "  ${GREEN}✓${NC} $name (exists)"
                    git -C "$target" pull --quiet 2>/dev/null || true
                else
                    if gh repo clone "$git_remote" "$target" -- --quiet 2>/dev/null; then
                        echo -e "  ${GREEN}✓${NC} $name"
                        ((cloned++))
                    else
                        echo -e "  ${YELLOW}⚠${NC}  $name — clone failed"
                    fi
                fi
            done
            echo -e "  Cloned $cloned new repos"
        fi
    else
        echo -e "${BLUE}[5/6]${NC} Project repos — skipped (use --all to clone)"
    fi

    # Step 6: Scan & finalize
    echo -e "${BLUE}[6/6]${NC} Running hq scan..."
    cmd_scan

    echo ""
    echo -e "${GREEN}${BOLD}✅ Bootstrap complete!${NC}"
    echo ""
    echo -e "Next steps:"
    echo -e "  cd ~/Projects/ClaudeHQ"
    echo -e "  claude                    # Start Claude Code"
    echo -e "  hq status                 # See all projects"
    echo -e "  hq session <project>      # Start working"
}

# --- DOCTOR ---
cmd_doctor() {
    if [[ ! -f "$PROJECTS_FILE" ]]; then
        echo -e "${RED}Error:${NC} projects.json not found. Run 'hq scan' first."
        exit 1
    fi

    local workspaces_dir="$HQ_DIR/workspaces"

    echo ""
    echo -e "${BOLD}🏥 ClaudeHQ Doctor${NC}"
    printf '══%.0s' {1..54}; echo ""

    # Collect project names and paths via Python (v2 schema: .projects is an object)
    local project_data
    project_data=$(python3 - "$PROJECTS_FILE" <<'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    data = json.load(f)

if isinstance(data, dict) and "projects" in data:
    projects = data["projects"]
    for name, info in projects.items():
        path = info.get("path", "")
        print(f"{name}\t{path}")
elif isinstance(data, list):
    for item in data:
        print("{}\t{}".format(item.get("name",""), item.get("path","")))
PYEOF
)

    if [[ -z "$project_data" ]]; then
        echo -e "${YELLOW}No projects found in projects.json.${NC}"
        echo ""
        return 0
    fi

    # Print header
    printf "${BOLD}%-22s %-16s %-13s %-14s${NC}\n" \
        "Project" "Symlink" "Path" "Git Remote"
    printf '──%.0s' {1..67}; echo ""

    local ok_count=0
    local warn_count=0
    local err_count=0

    while IFS=$'\t' read -r name raw_path; do
        [[ -z "$name" ]] && continue

        # Expand ~/
        local path="${raw_path/#\~/$HOME}"

        # --- Symlink check ---
        local symlink_status symlink_color
        local symlink_path="$workspaces_dir/$name"
        if [[ -L "$symlink_path" ]]; then
            if [[ -e "$symlink_path" ]]; then
                symlink_status="✅ OK"
                symlink_color="$GREEN"
                ok_count=$((ok_count + 1))
            else
                symlink_status="❌ BROKEN"
                symlink_color="$RED"
                err_count=$((err_count + 1))
            fi
        else
            symlink_status="⚠️ MISSING"
            symlink_color="$YELLOW"
            warn_count=$((warn_count + 1))
        fi

        # --- Path check ---
        local path_status path_color
        if [[ -d "$path" ]]; then
            path_status="✅ EXISTS"
            path_color="$GREEN"
            ok_count=$((ok_count + 1))
        else
            path_status="❌ MISSING"
            path_color="$RED"
            err_count=$((err_count + 1))
        fi

        # --- Git remote check ---
        local git_status git_color
        if [[ -d "$path" ]]; then
            if [[ -d "$path/.git" ]]; then
                local remote
                remote=$(git -C "$path" remote get-url origin 2>/dev/null || true)
                if [[ -n "$remote" ]]; then
                    git_status="✅ HAS_REMOTE"
                    git_color="$GREEN"
                    ok_count=$((ok_count + 1))
                else
                    git_status="⚠️ NO_REMOTE"
                    git_color="$YELLOW"
                    warn_count=$((warn_count + 1))
                fi
            else
                git_status="❌ NOT_GIT"
                git_color="$RED"
                err_count=$((err_count + 1))
            fi
        else
            git_status="—"
            git_color="$GRAY"
        fi

        printf "%-22s ${symlink_color}%-16s${NC} ${path_color}%-13s${NC} ${git_color}%-14s${NC}\n" \
            "$name" "$symlink_status" "$path_status" "$git_status"

    done <<< "$project_data"

    printf '──%.0s' {1..67}; echo ""

    # --- Dependency cycle check ---
    local cycle_result
    cycle_result=$(python3 - "$PROJECTS_FILE" <<'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    data = json.load(f)

if isinstance(data, dict) and "projects" in data:
    graph = {name: info.get("depends_on", []) for name, info in data["projects"].items()}
elif isinstance(data, list):
    graph = {item["name"]: item.get("depends_on", []) for item in data}
else:
    print("ACYCLIC")
    sys.exit(0)

# DFS cycle detection
WHITE, GRAY_STATE, BLACK = 0, 1, 2
color = {n: WHITE for n in graph}
cycle_path = []

def dfs(node, path):
    color[node] = GRAY_STATE
    path.append(node)
    for neighbor in graph.get(node, []):
        if neighbor not in color:
            continue
        if color[neighbor] == GRAY_STATE:
            cycle_path.extend(path)
            cycle_path.append(neighbor)
            return True
        if color[neighbor] == WHITE:
            if dfs(neighbor, path):
                return True
    path.pop()
    color[node] = BLACK
    return False

for node in list(graph.keys()):
    if color[node] == WHITE:
        if dfs(node, []):
            print("CYCLE: " + " -> ".join(cycle_path))
            sys.exit(0)

print("ACYCLIC")
PYEOF
)

    if [[ "$cycle_result" == "ACYCLIC" ]]; then
        printf "%-30s ${GREEN}✅ ACYCLIC${NC}\n" "Dependency graph:"
        ok_count=$((ok_count + 1))
    else
        printf "%-30s ${RED}❌ CYCLE_DETECTED: %s${NC}\n" "Dependency graph:" "${cycle_result#CYCLE: }"
        err_count=$((err_count + 1))
    fi

    # --- Orphan symlinks check ---
    local orphan_found=false
    if [[ -d "$workspaces_dir" ]]; then
        local known_names
        known_names=$(python3 - "$PROJECTS_FILE" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
if isinstance(data, dict) and "projects" in data:
    for name in data["projects"]:
        print(name)
elif isinstance(data, list):
    for item in data:
        print(item.get("name",""))
PYEOF
)

        while IFS= read -r symlink; do
            local sym_name
            sym_name=$(basename "$symlink")
            if ! grep -qxF "$sym_name" <<< "$known_names" 2>/dev/null; then
                printf "%-30s ${YELLOW}⚠️  ORPHAN: %s${NC}\n" "Orphan symlinks:" "$sym_name"
                warn_count=$((warn_count + 1))
                orphan_found=true
            fi
        done < <(find "$workspaces_dir" -maxdepth 1 -type l 2>/dev/null)
    fi

    if [[ "$orphan_found" == "false" ]]; then
        printf "%-30s ${GREEN}✅ NONE${NC}\n" "Orphan symlinks:"
        ok_count=$((ok_count + 1))
    fi

    printf '──%.0s' {1..67}; echo ""

    # --- Summary ---
    local summary="${GREEN}${ok_count} OK${NC}"
    if (( warn_count > 0 )); then
        local wlabel="warning"; (( warn_count > 1 )) && wlabel="warnings"
        summary+=", ${YELLOW}${warn_count} ${wlabel}${NC}"
    fi
    if (( err_count > 0 )); then
        local elabel="error"; (( err_count > 1 )) && elabel="errors"
        summary+=", ${RED}${err_count} ${elabel}${NC}"
    fi
    echo -e "Summary: $summary"
    echo ""
}

# --- LOGS ---
cmd_logs() {
    local project="${1:?Usage: hq logs <project>}"
    local log_file="$PROGRESS_DIR/${project}.log"

    if [[ ! -f "$log_file" ]]; then
        echo -e "${YELLOW}No logs found for $project.${NC}"
        echo "Logs are created when you dispatch a project."
        exit 0
    fi

    echo -e "${BOLD}Logs for $project${NC}\n"
    cat "$log_file"
}

# --- FEATURE ---
cmd_feature() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        start)   feature_start "$@" ;;
        status)  feature_status "$@" ;;
        commit)  feature_commit "$@" ;;
        push)    feature_push "$@" ;;
        pr)      feature_pr "$@" ;;
        merge)   feature_merge "$@" ;;
        abandon) feature_abandon "$@" ;;
        *)
            echo -e "${RED}Usage:${NC} hq feature <start|status|commit|push|pr|merge|abandon> [args]"
            echo ""
            echo "  hq feature start <name> [--repos=A,B,C]"
            echo "  hq feature status <name>"
            echo "  hq feature commit <name> -m \"message\""
            echo "  hq feature push <name>"
            echo "  hq feature pr <name> [--title \"...\"] [--body \"...\"]"
            echo "  hq feature merge <name> [--auto]"
            echo "  hq feature abandon <name>"
            exit 1
            ;;
    esac
}

# Resolve project path from projects.json v2 (keyed object, expands ~)
_feature_resolve_path() {
    local repo_name="$1"
    python3 - "$PROJECTS_FILE" "$repo_name" "$HOME" <<'PYEOF'
import sys, json
projects_file, repo_name, home = sys.argv[1], sys.argv[2], sys.argv[3]
with open(projects_file) as f:
    data = json.load(f)
projects = data.get("projects", {})
if repo_name not in projects:
    sys.exit(1)
path = projects[repo_name].get("path", "")
path = path.replace("~", home)
print(path)
PYEOF
}

feature_start() {
    local name=""
    local repos_arg=""

    for arg in "$@"; do
        case "$arg" in
            --repos=*) repos_arg="${arg#--repos=}" ;;
            -*) echo -e "${RED}Unknown option:${NC} $arg"; exit 1 ;;
            *) name="$arg" ;;
        esac
    done

    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage:${NC} hq feature start <name> [--repos=A,B,C]"
        exit 1
    fi

    if [[ ! -f "$PROJECTS_FILE" ]]; then
        echo -e "${RED}Error:${NC} projects.json not found. Run 'hq scan' first."
        exit 1
    fi

    # Determine repo list
    if [[ -z "$repos_arg" ]]; then
        echo -e "${YELLOW}No --repos specified.${NC}"
        echo "Enter comma-separated repo names (from projects.json):"
        read -r repos_arg
        if [[ -z "$repos_arg" ]]; then
            echo -e "${RED}Error:${NC} No repos provided."
            exit 1
        fi
    fi

    IFS=',' read -ra repo_names <<< "$repos_arg"

    local branch="feature/$name"
    local created_repos=()

    # First pass: validate all repos exist before touching any branch
    for raw_name in "${repo_names[@]}"; do
        local repo_name
        repo_name="$(echo "$raw_name" | tr -d '[:space:]')"
        [[ -z "$repo_name" ]] && continue

        if ! _feature_resolve_path "$repo_name" &>/dev/null; then
            echo -e "${RED}Error:${NC} Repo '$repo_name' not found in projects.json"
            exit 1
        fi

        local repo_path
        repo_path=$(_feature_resolve_path "$repo_name")
        if [[ ! -d "$repo_path" ]]; then
            echo -e "${RED}Error:${NC} Path not found for '$repo_name': $repo_path"
            exit 1
        fi
    done

    # Second pass: create branches
    for raw_name in "${repo_names[@]}"; do
        local repo_name repo_path
        repo_name="$(echo "$raw_name" | tr -d '[:space:]')"
        [[ -z "$repo_name" ]] && continue
        repo_path=$(_feature_resolve_path "$repo_name")

        if git -C "$repo_path" checkout -b "$branch" 2>/dev/null; then
            echo -e "  ${GREEN}+${NC} $repo_name — branch '$branch' created"
            created_repos+=("$repo_name")
        elif git -C "$repo_path" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
            echo -e "  ${YELLOW}!${NC} $repo_name — branch '$branch' already exists, skipping"
            created_repos+=("$repo_name")
        else
            echo -e "${RED}Error:${NC} Failed to create branch '$branch' in '$repo_name'"
            # Rollback branches created in this run
            for rb_name in "${created_repos[@]}"; do
                local rb_path
                rb_path=$(_feature_resolve_path "$rb_name") || continue
                git -C "$rb_path" checkout - 2>/dev/null || true
                git -C "$rb_path" branch -D "$branch" 2>/dev/null || true
                echo -e "  ${YELLOW}Rolled back${NC} $rb_name"
            done
            exit 1
        fi
    done

    if [[ ${#created_repos[@]} -eq 0 ]]; then
        echo -e "${RED}Error:${NC} No repos were processed."
        exit 1
    fi

    # Build repo entries JSON and write state file
    mkdir -p "$FEATURES_DIR"
    local feature_file="$FEATURES_DIR/${name}.json"

    python3 - "$feature_file" "$name" "$branch" "$PROJECTS_FILE" "$HOME" "${created_repos[@]}" <<'PYEOF'
import sys, json
from datetime import date

feature_file  = sys.argv[1]
name          = sys.argv[2]
branch        = sys.argv[3]
projects_file = sys.argv[4]
home          = sys.argv[5]
repo_names    = sys.argv[6:]

with open(projects_file) as f:
    data = json.load(f)
all_projects = data.get("projects", {})

repos = []
for rname in repo_names:
    path = all_projects.get(rname, {}).get("path", "").replace("~", home)
    repos.append({
        "name": rname,
        "path": path,
        "branch": branch,
        "pr": None,
        "status": "local"
    })

state = {
    "name": name,
    "created": str(date.today()),
    "repos": repos,
    "linked_pr_group": name
}
with open(feature_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF

    local repos_display
    repos_display=$(IFS=', '; echo "${created_repos[*]}")
    echo ""
    echo -e "${GREEN}Feature '$name' started in:${NC} $repos_display"
    echo "State saved to: $feature_file"
}

feature_status() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage:${NC} hq feature status <name>"
        exit 1
    fi

    local feature_file="$FEATURES_DIR/${name}.json"

    if [[ ! -f "$feature_file" ]]; then
        echo -e "${RED}Error:${NC} Feature '$name' not found (expected: $feature_file)"
        exit 1
    fi

    echo -e "\n${BOLD}Feature: $name${NC}"
    echo ""

    python3 - "$feature_file" <<'PYEOF'
import sys, json, subprocess

feature_file = sys.argv[1]
with open(feature_file) as f:
    state = json.load(f)

BOLD   = "\033[1m"
GREEN  = "\033[0;32m"
YELLOW = "\033[1;33m"
GRAY   = "\033[0;90m"
NC     = "\033[0m"

print(f"  Created:  {state.get('created', '-')}")
print(f"  PR group: {state.get('linked_pr_group', '-')}")
print()

for repo in state.get("repos", []):
    rname  = repo["name"]
    path   = repo["path"]
    branch = repo["branch"]
    status = repo.get("status", "unknown")

    print(f"  {BOLD}{rname}{NC}  [{branch}]  status={status}")

    # Uncommitted changes
    try:
        r = subprocess.run(
            ["git", "-C", path, "status", "--short"],
            capture_output=True, text=True
        )
        lines = [l for l in r.stdout.strip().splitlines() if l]
        if lines:
            print(f"    {YELLOW}Uncommitted changes: {len(lines)}{NC}")
            for l in lines[:5]:
                print(f"      {l}")
            if len(lines) > 5:
                print(f"      ... and {len(lines) - 5} more")
        else:
            print(f"    {GREEN}No uncommitted changes{NC}")
    except Exception as e:
        print(f"    [git status error: {e}]")

    # Last 3 commits
    try:
        r = subprocess.run(
            ["git", "-C", path, "log", "--oneline", "-3"],
            capture_output=True, text=True
        )
        commits = r.stdout.strip().splitlines()
        if commits:
            print(f"    Last commits:")
            for c in commits:
                print(f"      {GRAY}{c}{NC}")
        else:
            print(f"    No commits yet")
    except Exception as e:
        print(f"    [git log error: {e}]")

    print()
PYEOF
}

feature_commit() {
    local name=""
    local message=""
    local args=("$@")
    local i=0

    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"
        case "$arg" in
            -m)
                i=$(( i + 1 ))
                message="${args[$i]:-}"
                ;;
            -m*)
                message="${arg#-m}"
                ;;
            -*)
                echo -e "${RED}Unknown option:${NC} $arg"
                exit 1
                ;;
            *)
                name="$arg"
                ;;
        esac
        i=$(( i + 1 ))
    done

    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage:${NC} hq feature commit <name> -m \"message\""
        exit 1
    fi

    if [[ -z "$message" ]]; then
        echo -e "${RED}Error:${NC} Commit message required (-m \"message\")"
        exit 1
    fi

    local feature_file="$FEATURES_DIR/${name}.json"

    if [[ ! -f "$feature_file" ]]; then
        echo -e "${RED}Error:${NC} Feature '$name' not found (expected: $feature_file)"
        exit 1
    fi

    local committed=0
    local skipped=0

    echo -e "\n${BOLD}Committing feature '$name'${NC}\n"

    local repo_count
    repo_count=$(python3 -c "import json; d=json.load(open('$feature_file')); print(len(d.get('repos', [])))")

    for i in $(seq 0 $(( repo_count - 1 ))); do
        local repo_name repo_path
        repo_name=$(python3 -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['name'])")
        repo_path=$(python3 -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['path'])")

        if [[ ! -d "$repo_path" ]]; then
            echo -e "  ${YELLOW}[skip]${NC} $repo_name: path not found ($repo_path)"
            skipped=$(( skipped + 1 ))
            continue
        fi

        local porcelain
        porcelain=$(git -C "$repo_path" status --porcelain 2>/dev/null || true)

        if [[ -z "$porcelain" ]]; then
            echo -e "  ${GRAY}[skip]${NC} $repo_name: no changes"
            skipped=$(( skipped + 1 ))
        else
            if git -C "$repo_path" add -A && git -C "$repo_path" commit -m "$message"; then
                echo -e "  ${GREEN}[committed]${NC} $repo_name"
                committed=$(( committed + 1 ))
            else
                echo -e "  ${RED}[error]${NC} $repo_name: commit failed"
                skipped=$(( skipped + 1 ))
            fi
        fi
    done

    echo ""
    echo -e "${GREEN}Done.${NC} Committed in $committed repo(s), skipped $skipped repo(s)."
}

# Helper: derive owner/repo from a git remote URL
_feature_owner_repo() {
    local path="$1"
    local remote_url
    remote_url=$(git -C "$path" remote get-url origin 2>/dev/null || true)
    # Support both https://github.com/owner/repo and git@github.com:owner/repo
    python3 -c "
import sys, re
url = '''$remote_url'''
m = re.search(r'github\.com[:/](.+?)(?:\.git)?$', url)
print(m.group(1) if m else '')
"
}

# --- FEATURE PUSH ---
feature_push() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage:${NC} hq feature push <name>"
        exit 1
    fi

    local feature_file="$FEATURES_DIR/${name}.json"

    if [[ ! -f "$feature_file" ]]; then
        echo -e "${RED}Error:${NC} Feature '$name' not found (expected: $feature_file)"
        exit 1
    fi

    echo -e "\n${BOLD}Pushing feature '$name'${NC}\n"

    python3 - "$feature_file" <<'PYEOF'
import sys, json, subprocess

feature_file = sys.argv[1]
with open(feature_file) as f:
    state = json.load(f)

GREEN  = "\033[0;32m"
YELLOW = "\033[1;33m"
NC     = "\033[0m"

pushed  = []
skipped = []

for repo in state.get("repos", []):
    rname  = repo["name"]
    path   = repo["path"]
    branch = repo["branch"]
    status = repo.get("status", "local")

    if status != "local":
        skipped.append(f"{rname} (status: {status})")
        continue

    result = subprocess.run(
        ["git", "-C", path, "push", "-u", "origin", branch],
        capture_output=True, text=True
    )
    if result.returncode == 0:
        repo["status"] = "pushed"
        pushed.append(rname)
    else:
        print(f"  {YELLOW}[error]{NC} {rname}: {result.stderr.strip()}")
        skipped.append(f"{rname} (push failed)")

with open(feature_file, "w") as f:
    json.dump(state, f, indent=2)

pushed_str  = ", ".join(pushed)  if pushed  else "none"
skipped_str = " | ".join(f"\u23ed\ufe0f Skipped: {s}" for s in skipped) if skipped else ""

line = f"\u2705 Pushed: {pushed_str}"
if skipped_str:
    line += f" | {skipped_str}"
print(line)
PYEOF
}

# --- FEATURE PR ---
feature_pr() {
    local name=""
    local title=""
    local body=""
    local args=("$@")
    local i=0

    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"
        case "$arg" in
            --title)
                i=$(( i + 1 ))
                title="${args[$i]:-}"
                ;;
            --title=*)
                title="${arg#--title=}"
                ;;
            --body)
                i=$(( i + 1 ))
                body="${args[$i]:-}"
                ;;
            --body=*)
                body="${arg#--body=}"
                ;;
            -*)
                echo -e "${RED}Unknown option:${NC} $arg"
                exit 1
                ;;
            *)
                name="$arg"
                ;;
        esac
        i=$(( i + 1 ))
    done

    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage:${NC} hq feature pr <name> [--title \"...\"] [--body \"...\"]"
        exit 1
    fi

    local feature_file="$FEATURES_DIR/${name}.json"

    if [[ ! -f "$feature_file" ]]; then
        echo -e "${RED}Error:${NC} Feature '$name' not found (expected: $feature_file)"
        exit 1
    fi

    # Default title
    if [[ -z "$title" ]]; then
        title="feat: $name"
    fi

    echo -e "\n${BOLD}Creating PRs for feature '$name'${NC}\n"

    local repo_count
    repo_count=$(python3 -c "import json; d=json.load(open('$feature_file')); print(len(d.get('repos', [])))")

    local updated_any=false

    for i in $(seq 0 $(( repo_count - 1 ))); do
        local repo_name repo_path repo_branch repo_status repo_pr
        repo_name=$(python3   -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['name'])")
        repo_path=$(python3   -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['path'])")
        repo_branch=$(python3 -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['branch'])")
        repo_status=$(python3 -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i].get('status','local'))")

        if [[ "$repo_status" == "local" ]]; then
            echo -e "  ${YELLOW}[skip]${NC} $repo_name — push first (status: local)"
            continue
        fi

        if [[ "$repo_status" == "pr_open" ]]; then
            local existing_pr
            existing_pr=$(python3 -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i].get('pr') or '')")
            echo -e "  ${YELLOW}[skip]${NC} $repo_name — PR already open (#$existing_pr)"
            continue
        fi

        if [[ "$repo_status" == "merged" || "$repo_status" == "abandoned" ]]; then
            echo -e "  ${YELLOW}[skip]${NC} $repo_name — status: $repo_status"
            continue
        fi

        # Derive owner/repo
        local owner_repo
        owner_repo=$(_feature_owner_repo "$repo_path")
        if [[ -z "$owner_repo" ]]; then
            echo -e "  ${RED}[error]${NC} $repo_name — could not determine GitHub owner/repo"
            continue
        fi

        local full_body="$body"$'\n\n'"🔗 Part of feature group: $name"

        local pr_url
        pr_url=$(gh pr create \
            --repo "$owner_repo" \
            --title "$title" \
            --body "$full_body" \
            --label "feature-group/$name" \
            --head "$repo_branch" \
            2>&1) || true

        if echo "$pr_url" | grep -q "https://github.com"; then
            # Extract PR number from URL
            local pr_number
            pr_number=$(echo "$pr_url" | grep -oE 'https://github\.com/[^/]+/[^/]+/pull/([0-9]+)' | grep -oE '[0-9]+$' || echo "")

            # Update state file
            python3 - "$feature_file" "$i" "$pr_number" <<'PYEOF'
import sys, json
feature_file = sys.argv[1]
idx          = int(sys.argv[2])
pr_number    = sys.argv[3]
with open(feature_file) as f:
    state = json.load(f)
state["repos"][idx]["status"] = "pr_open"
state["repos"][idx]["pr"]     = int(pr_number) if pr_number.isdigit() else pr_number
with open(feature_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
            updated_any=true
            echo -e "  ${GREEN}[created]${NC} $repo_name — $pr_url"
        else
            echo -e "  ${RED}[error]${NC} $repo_name — gh pr create failed:"
            echo "    $pr_url"
        fi
    done

    if [[ "$updated_any" == "true" ]]; then
        echo ""
        echo -e "${GREEN}Done.${NC} State updated in $feature_file"
    fi
}

# --- FEATURE MERGE ---
feature_merge() {
    local name=""
    local auto_mode=false
    local args=("$@")
    local i=0

    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[$i]}"
        case "$arg" in
            --auto) auto_mode=true ;;
            -*)
                echo -e "${RED}Unknown option:${NC} $arg"
                exit 1
                ;;
            *) name="$arg" ;;
        esac
        i=$(( i + 1 ))
    done

    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage:${NC} hq feature merge <name> [--auto]"
        exit 1
    fi

    local feature_file="$FEATURES_DIR/${name}.json"

    if [[ ! -f "$feature_file" ]]; then
        echo -e "${RED}Error:${NC} Feature '$name' not found (expected: $feature_file)"
        exit 1
    fi

    echo -e "\n${BOLD}Merging feature '$name'${NC}\n"

    # Build ordered repo list using depends_on topological sort from projects.json
    local ordered_repos
    ordered_repos=$(python3 - "$feature_file" "$PROJECTS_FILE" <<'PYEOF'
import sys, json
from collections import defaultdict, deque

feature_file  = sys.argv[1]
projects_file = sys.argv[2]

with open(feature_file) as f:
    state = json.load(f)
with open(projects_file) as f:
    pdata = json.load(f)

# Support both array and object schema for projects.json
if isinstance(pdata, dict) and "projects" in pdata:
    all_projects = pdata["projects"]
    def get_deps(name):
        return all_projects.get(name, {}).get("depends_on", [])
elif isinstance(pdata, list):
    all_projects = {p["name"]: p for p in pdata}
    def get_deps(name):
        return all_projects.get(name, {}).get("depends_on", [])
else:
    all_projects = {}
    def get_deps(name):
        return []

repo_names = [r["name"] for r in state.get("repos", [])]
repo_set   = set(repo_names)

# Build adjacency (dependency must come first)
in_degree  = defaultdict(int)
adj        = defaultdict(list)

for rname in repo_names:
    for dep in get_deps(rname):
        if dep in repo_set:
            adj[dep].append(rname)
            in_degree[rname] += 1

queue = deque([r for r in repo_names if in_degree[r] == 0])
order = []
while queue:
    node = queue.popleft()
    order.append(node)
    for nxt in adj[node]:
        in_degree[nxt] -= 1
        if in_degree[nxt] == 0:
            queue.append(nxt)

# Append any remaining (cycle fallback)
for r in repo_names:
    if r not in order:
        order.append(r)

print("\n".join(order))
PYEOF
)

    local merged_count=0
    local failed=false

    while IFS= read -r repo_name; do
        [[ -z "$repo_name" ]] && continue

        # Read repo state
        local repo_status repo_pr repo_path
        repo_status=$(python3 -c "
import json
state = json.load(open('$feature_file'))
repo = next((r for r in state['repos'] if r['name'] == '$repo_name'), None)
print(repo.get('status','') if repo else '')
")
        repo_pr=$(python3 -c "
import json
state = json.load(open('$feature_file'))
repo = next((r for r in state['repos'] if r['name'] == '$repo_name'), None)
print(repo.get('pr') or '' if repo else '')
")
        repo_path=$(python3 -c "
import json
state = json.load(open('$feature_file'))
repo = next((r for r in state['repos'] if r['name'] == '$repo_name'), None)
print(repo.get('path','') if repo else '')
")

        if [[ "$repo_status" != "pr_open" ]]; then
            echo -e "  ${YELLOW}[skip]${NC} $repo_name — status: $repo_status (expected pr_open)"
            continue
        fi

        if [[ -z "$repo_pr" ]]; then
            echo -e "  ${YELLOW}[skip]${NC} $repo_name — no PR number recorded"
            continue
        fi

        local owner_repo
        owner_repo=$(_feature_owner_repo "$repo_path")
        if [[ -z "$owner_repo" ]]; then
            echo -e "  ${RED}[error]${NC} $repo_name — could not determine GitHub owner/repo"
            continue
        fi

        if [[ "$auto_mode" == "true" ]]; then
            # Check CI status
            local ci_result
            ci_result=$(gh pr view "$repo_pr" --repo "$owner_repo" --json statusCheckRollup 2>/dev/null || echo '{}')
            local all_pass
            all_pass=$(python3 -c "
import json, sys
data = json.loads('''$ci_result''')
checks = data.get('statusCheckRollup', [])
if not checks:
    print('no_checks')
    sys.exit(0)
failed = [c for c in checks if c.get('conclusion','') not in ('SUCCESS','NEUTRAL','SKIPPED','') and c.get('status','') == 'COMPLETED']
pending = [c for c in checks if c.get('status','') not in ('COMPLETED',)]
if failed:
    print('failed:' + ','.join(c.get('name','?') for c in failed))
elif pending:
    print('pending:' + ','.join(c.get('name','?') for c in pending))
else:
    print('pass')
")
            if [[ "$all_pass" == "pass" || "$all_pass" == "no_checks" ]]; then
                echo -e "  ${GREEN}[auto-merge]${NC} $repo_name — PR #$repo_pr"
            elif [[ "$all_pass" == pending:* ]]; then
                echo -e "  ${RED}[blocked]${NC} $repo_name — CI checks still pending: ${all_pass#pending:}"
                echo -e "${RED}Stopping.${NC} Remaining repos not merged."
                exit 1
            else
                echo -e "  ${RED}[blocked]${NC} $repo_name — CI checks failed: ${all_pass#failed:}"
                echo -e "${RED}Stopping.${NC} Remaining repos not merged."
                exit 1
            fi
        else
            # Manual prompt
            echo -n "  Merge PR #$repo_pr in $repo_name? [y/N] "
            read -r answer
            if [[ ! "$answer" =~ ^[Yy]$ ]]; then
                echo -e "  ${YELLOW}[skipped]${NC} $repo_name"
                continue
            fi
        fi

        # Perform merge
        if gh pr merge "$repo_pr" --repo "$owner_repo" --merge 2>&1; then
            # Update state
            python3 - "$feature_file" "$repo_name" <<'PYEOF'
import sys, json
feature_file = sys.argv[1]
repo_name    = sys.argv[2]
with open(feature_file) as f:
    state = json.load(f)
for repo in state["repos"]:
    if repo["name"] == repo_name:
        repo["status"] = "merged"
        break
with open(feature_file, "w") as f:
    json.dump(state, f, indent=2)
PYEOF
            echo -e "  ${GREEN}[merged]${NC} $repo_name — PR #$repo_pr"
            merged_count=$(( merged_count + 1 ))
        else
            echo -e "  ${RED}[error]${NC} $repo_name — merge failed"
            if [[ "$auto_mode" == "true" ]]; then
                echo -e "${RED}Stopping in --auto mode.${NC} Remaining repos not merged."
                exit 1
            fi
            echo -n "  Continue anyway? [y/N] "
            read -r cont
            if [[ ! "$cont" =~ ^[Yy]$ ]]; then
                echo -e "${YELLOW}Stopped.${NC} Some repos may still have open PRs."
                exit 1
            fi
        fi
    done <<< "$ordered_repos"

    echo ""
    echo -e "${GREEN}Done.${NC} Merged $merged_count PR(s)."
}

# --- FEATURE ABANDON ---
feature_abandon() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        echo -e "${RED}Usage:${NC} hq feature abandon <name>"
        exit 1
    fi

    local feature_file="$FEATURES_DIR/${name}.json"

    if [[ ! -f "$feature_file" ]]; then
        echo -e "${RED}Error:${NC} Feature '$name' not found (expected: $feature_file)"
        exit 1
    fi

    echo -e "\n${BOLD}Abandoning feature '$name'${NC}\n"

    local repo_count
    repo_count=$(python3 -c "import json; d=json.load(open('$feature_file')); print(len(d.get('repos', [])))")

    local cleaned=()

    for i in $(seq 0 $(( repo_count - 1 ))); do
        local repo_name repo_path repo_branch repo_status repo_pr
        repo_name=$(python3   -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['name'])")
        repo_path=$(python3   -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['path'])")
        repo_branch=$(python3 -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i]['branch'])")
        repo_status=$(python3 -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i].get('status','local'))")
        repo_pr=$(python3     -c "import json; d=json.load(open('$feature_file')); print(d['repos'][$i].get('pr') or '')")

        if [[ ! -d "$repo_path" ]]; then
            echo -e "  ${YELLOW}[skip]${NC} $repo_name — path not found ($repo_path)"
            continue
        fi

        # Checkout main/master
        git -C "$repo_path" checkout main 2>/dev/null || \
            git -C "$repo_path" checkout master 2>/dev/null || true

        # Delete local branch
        if git -C "$repo_path" branch -D "$repo_branch" 2>/dev/null; then
            echo -e "  ${GREEN}[deleted local]${NC} $repo_name — $repo_branch"
        else
            echo -e "  ${YELLOW}[no local branch]${NC} $repo_name — $repo_branch"
        fi

        # Delete remote branch if pushed
        if [[ "$repo_status" == "pushed" || "$repo_status" == "pr_open" ]]; then
            if git -C "$repo_path" push origin --delete "$repo_branch" 2>/dev/null; then
                echo -e "  ${GREEN}[deleted remote]${NC} $repo_name — origin/$repo_branch"
            else
                echo -e "  ${YELLOW}[remote branch not found]${NC} $repo_name — origin/$repo_branch"
            fi
        fi

        # Close open PR
        if [[ "$repo_status" == "pr_open" && -n "$repo_pr" ]]; then
            local owner_repo
            owner_repo=$(_feature_owner_repo "$repo_path")
            if [[ -n "$owner_repo" ]]; then
                if gh pr close "$repo_pr" --repo "$owner_repo" 2>/dev/null; then
                    echo -e "  ${GREEN}[closed PR]${NC} $repo_name — #$repo_pr"
                else
                    echo -e "  ${YELLOW}[PR close failed]${NC} $repo_name — #$repo_pr"
                fi
            fi
        fi

        cleaned+=("$repo_name")
    done

    # Delete state file
    rm -f "$feature_file"

    local cleaned_str
    cleaned_str=$(IFS=', '; echo "${cleaned[*]}")
    echo ""
    echo -e "${GREEN}✅ Abandoned feature '$name'${NC} — branches deleted in: $cleaned_str"
}

# --- MAIN ---
case "${1:-}" in
    scan)       shift; cmd_scan "$@" ;;
    new)        shift; cmd_new "$@" ;;
    session)    shift; cmd_session "$@" ;;
    dispatch)   shift; cmd_dispatch "$@" ;;
    status)     shift; cmd_status "$@" ;;
    sprint)     shift; cmd_sprint "$@" ;;
    monitor)    shift; cmd_monitor "$@" ;;
    stuck)      shift; cmd_stuck "$@" ;;
    archive)    shift; cmd_archive "$@" ;;
    activate)   shift; cmd_activate "$@" ;;
    config)     shift; cmd_config "$@" ;;
    logs)       shift; cmd_logs "$@" ;;
    sync)       shift; exec "$HQ_DIR/scripts/sync-ecosystem.sh" "$@" ;;
    bootstrap)  shift; cmd_bootstrap "$@" ;;
    doctor)     shift; cmd_doctor "$@" ;;
    feature)    shift; cmd_feature "$@" ;;
    --help|-h)  usage ;;
    *)          usage ;;
esac
